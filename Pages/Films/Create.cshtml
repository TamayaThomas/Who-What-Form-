@page
@model Who_What_Form_.Pages_Films.CreateModel

        @{
        ViewData["Title"] = "Create";
        }
        
        <h1>Create</h1>
        
    <h4>Film</h4>
    <hr />
    <div class="row">
    <div class="col-md-4">
    <form method="post" enctype="multipart/form-data">
    <div asp-validation-summary="ModelOnly" class="text-danger"></div>
            <div class="form-group">
                <label asp-for="Film.Title" class="control-label"></label>
                <input asp-for="Film.Title" class="form-control" />
                <span asp-validation-for="Film.Title" class="text-danger"></span>
            </div>
            <div class="form-group">@*https://www.w3schools.com/bootstrap5/tryit.asp?filename=trybs_form_select&stacked=h*@
                <label asp-for="Film.Rating" class="control-label"></label>
                <select asp-for="Film.Rating" class="form-select"  name="rating" id="ratings">
                    <option>G</option>@*https://en.wikipedia.org/wiki/Motion_Picture_Association_film_rating_system*@
                    <option>PG</option>
                    <option>PG-13</option>
                    <option>R</option>
                    <option>NC-17</option>
                    <option>Not Rated (NR)</option>
                    <option>Unrated (UR)</option>
                </select>
                <span asp-validation-for="Film.Rating" class="text-danger"></span>
            </div>
            <div class="form-group">
                <label asp-for="Film.Description" class="control-label"></label>
                <input asp-for="Film.Description" class="form-control" />
                <span asp-validation-for="Film.Description" class="text-danger"></span>
            </div>
            <div class="form-group">@*https://www.w3schools.com/tags/att_input_type_file.asp*@
                <label asp-for="Film.ImageUrl" class="control-label"></label>
                <input type="file" name="ImageFile" class="form-control" />
                <span asp-validation-for="Film.ImageUrl" class="text-danger"></span>
            </div>
            <div class="form-group">
                <input type="submit" value="Create" class="btn btn-primary" />
            </div>
        </form>
    </div>
</div>

<div>
    <a asp-page="Index">Back to List</a>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
