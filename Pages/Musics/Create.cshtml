@page
@model Who_What_Form_.Pages_Musics.CreateModel

        @{
        ViewData["Title"] = "Create";
        }
        
        <h1>Create</h1>
        
    <h4>Music</h4>
    <hr />
    <div class="row">
    <div class="col-md-4">
    <form method="post" enctype="multipart/form-data">
    <div asp-validation-summary="ModelOnly" class="text-danger"></div>
            <div class="form-group">
                <span class="text-danger">*</span>
                <label asp-for="Music.SongTitle" class="control-label"></label>
                <input asp-for="Music.SongTitle" class="form-control" aria-required="true"/>
                <span asp-validation-for="Music.SongTitle" class="text-danger"></span>
            </div>
            <div class="form-group">
                <span class="text-danger">*</span>
                <label asp-for="Music.ArtistName" class="control-label"></label>
                <input asp-for="Music.ArtistName" class="form-control" aria-required="true"/>
                <span asp-validation-for="Music.ArtistName" class="text-danger"></span>
            </div>
            <div class="form-group">
                <label asp-for="Music.ImageUrl" class="control-label"></label>
                <input asp-for="ImageFile" type="file" class="form-control" />
                <span asp-validation-for="Music.ImageUrl" class="text-danger"></span>
            </div>
            <div class="form-group">
                <label asp-for="Music.FilmID" class="control-label"></label>
                <select asp-for="Music.FilmID" class ="form-control" asp-items="ViewBag.FilmID" >
                    <option value="0">Choose...</option>
                </select>
            </div>
            <div class="form-group">
                <input type="submit" value="Create" class="btn btn-primary" />
            </div>
        </form>
    </div>
</div>

<div>
    <a asp-page="Index">Back to List</a>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
